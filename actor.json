{
    "actorSpecification": 1,
    "name": "agritech-buyer-discovery",
    "title": "AgriTech B2B Buyer Discovery",
    "description": "Find international B2B buyers for agricultural commodities on global trade directories",
    "version": "0.1",
    "meta": {
        "templateId": "js-cheerio-crawler"
    },
    "input": "./input_schema.json",
    "dockerfile": "../Dockerfile",
    "storages": {
        "dataset": {
            "actorSpecification": 1,
            "title": "Buyer Leads",
            "views": {
                "leads": {
                    "title": "Discovered Buyer Leads",
                    "transformation": {
                        "fields": [
                            "platform",
                            "title",
                            "commodity",
                            "buyerCountry",
                            "quantity",
                            "postedDate",
                            "contactUrl"
                        ]
                    },
                    "display": {
                        "component": "table",
                        "properties": {
                            "platform": { "label": "Platform", "format": "text" },
                            "title": { "label": "Buyer Request", "format": "text" },
                            "commodity": { "label": "Commodity", "format": "text" },
                            "buyerCountry": { "label": "Country", "format": "text" },
                            "quantity": { "label": "Quantity", "format": "text" },
                            "postedDate": { "label": "Posted", "format": "text" },
                            "contactUrl": { "label": "Contact", "format": "link" }
                        }
                    }
                }
            }
        }
    }
}